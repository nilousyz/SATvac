T12_669 = [701722	968534	1268105	971808	910307];
T25_669 = [227018	177750	14351	122582	277604];


M5_577 = [48	116	146	9];
M8_577 = [47698	46801	7650	22854];
M12_577 = [13936	42083	18149	14359];
M26_577 = [698	277	173];

M5_595 = [0	4	4	0	5];
M7_595 = [65824	152389	59295	62147	285309];
M9_595 = [95737	125079	150220	110162	158026];
M13_595 = [46489	53553	71585	52937	82990];

M5_669 = [224	2634	236	646	1012];
M6_669 = [5212	7045	6653	12292	2878];
M7_669 = [45062	40704	57080	62137	22304];
M8_669 = [74181	21550	81436	62344	99569];
M9_669 = [51021	51571	45186	78051	121319];
M12_669 = [58057	64886	50124	62892	56290];
M25_669 = [10043	13976	1494	7471	20825];


Ef5_577 = [609	6954	1952	62];
Ef8_577 = [1519595	820118	312215	1951982];
Ef12_577 = [175403	240310	203708	392471];
Ef26_577 = [55599	2133	26548];

Ef5_595 = [5456	4690	13002	7170	7371];
Ef7_595 = [744955	1924391	1363486	882747	4442013];
Ef9_595 = [403000	846926	962284	1182215	1382348];
Ef13_595 = [340380	541334	863914	1018391	1142569];

Ef5_669 = [87	919	24	611	120];
Ef6_669 = [57925	233275	20688	103306	79505];
Ef7_669 = [654048	557809	865168	423569	434923];
Ef8_669 = [1508035	1322096	3587009	1844230	1501176];
Ef9_669 = [1168221	2054125	807978	1302932	2522439];
Ef12_669 = [409792	586709	790488	595869	537047];
Ef25_669 = [158044	97135	7461	72794	161462];

time(1:26) = ((1:1:26)+1)*24;

if Exp_N == 1
    figure
    scatter(x(index),(result(:,index)),10,'o','MarkerFaceColor','black','MarkerEdgeColor','none','MarkerFaceAlpha','0.01')
    hold on
    scatter(time(5),T5_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(6),T6_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(7),T7_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(8),T8_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(9),T9_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(12),T12_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(25),T25_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    legend("Simulation Results Total OT-I T Cell","Experimental Results-Training Set Case 1")
    title("Total OT-I Cell")
    ylabel("Number of Total OT-I cell")
    xlabel("Time (Days Post Immunization)")
    custom_xticks = [0,144, 168, 192, 216, 240, 312, 336, 624];
    custom_xticklabels = ["-1","5","6","7", "8","9","12","13","25"];
    xticks(custom_xticks);
    xticklabels(custom_xticklabels);
    xlim([0 649])
    ax = gca;
    ax.FontSize = 20;


    figure
    scatter(x(index),memory_result(:,index),10,'o','MarkerFaceColor','black','MarkerEdgeColor','none','MarkerFaceAlpha','0.01')
    hold on
    scatter(time(5),M5_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    scatter(time(6),M6_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    scatter(time(7),M7_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    scatter(time(8),M8_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    scatter(time(9),M9_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor","#EDB120")
    scatter(time(12),M12_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    scatter(time(25),M25_669,90,'o','MarkerFaceColor',"#EDB120","MarkerEdgeColor",'#EDB120')
    legend("Simulation Results Total Memory Precursor OT-I T Cell","Experimental Results-Training Set Case 1")
    title("Total Memory Precursor OT-I T Cell")
    xlabel("Time (Days Post Immunization)")
    ylabel("Number of Memory Precursor OT-I T Cell")
    custom_xticks = [0,144, 168, 192, 216, 240, 312, 336, 624];
