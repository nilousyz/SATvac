function plot_simulation_results_cloud(X,Exp_N,stoptime,steptime)

addpath("Functions")
if Exp_N ==2
    X(6) = 1300;
elseif Exp_N ==3
    X(6)= 3500;
end
poolobj = gcp('nocreate');
if ~isempty(poolobj)
    delete(poolobj);
end

parpool

parfor i=1:1:2
    [dat,total] = MouseSim(round(X(6)),round(X(6)/X(1)),X(2),X(4),X(5),X(3),stoptime,steptime, X(7),X(8),X(9),X(10),X(11));
    result(i,:) = total(:,2);
    memory_result(i,:) = dat(:,16);
    effector_result(i,:) = dat(:,17);
end
x = 0:0.1:648.1;
index = 1:1:6481;

T5_577 = [3572	23813	5628	1080];
T8_577 = [1788298	1023024	393377	2242979];
T12_577 = [215977	324719	252003	439938];
T26_577 = [61763	0	3373	30576];

T5_595 = [10043 7990 21534 15029 13352];
T7_595 = [1157715 2906500 1817117 1316906 6245287];
T9_595 = [644240 	 1186539 	 1391044 	 1502553 	 1815504];
T13_595 = [342414	150124	285345	518698	372197];

T5_669 = [1033	8510	884	4315	2691];
T6_669 = [105051	378661	66169	228561	115788];
T7_669 = [1218558	1084086	1386823	875512	822928];
