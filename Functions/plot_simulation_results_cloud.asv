    scatter(time(8),Ef8_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(9),Ef9_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(12),Ef12_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    scatter(time(25),Ef25_669,90,'o','MarkerFaceColor',"#FF0000","MarkerEdgeColor","#FF0000")
    legend("Simulation Results Total Effector T Cell","Experimental Results-Training Set Case 1")
    title("Total Effector T Cell")
    xlabel("Time (Days Post Immunization)")
    ylabel("Number of Effector T Cell")
    custom_xticks = [0,144, 168, 192, 216, 240, 312, 336, 624];
    custom_xticklabels = ["-1","5","6","7", "8","9","12","13","25"];
    xticks(custom_xticks);
    xticklabels(custom_xticklabels);
    xlim([0 649])
    ax = gca;
    ax.FontSize = 20;
end

